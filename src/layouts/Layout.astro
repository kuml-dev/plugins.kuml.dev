---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'kUML Plugin Registry',
  description = 'Themes, renderers, layout engines, codegen and reverse-engineering extensions for kUML.',
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <header class="site-header">
      <div class="container site-header__inner">
        <a href="/" class="site-header__logo">
          <span>kUML</span> Plugin Registry
        </a>
        <nav class="site-header__nav">
          <a href="https://kuml.dev" target="_blank" rel="noopener">kuml.dev</a>
          <a href="https://github.com/kuml-dev/kUML" target="_blank" rel="noopener">GitHub</a>
          <a href="/plugins/index.json" target="_blank" rel="noopener">API</a>
        </nav>
      </div>
    </header>

    <main class="container">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>
          kUML Plugin Registry &mdash; Apache-2.0 &mdash;
          <a href="https://github.com/kuml-dev/kUML" target="_blank" rel="noopener">github.com/kuml-dev/kUML</a>
        </p>
      </div>
    </footer>
  </body>
</html>
